meta {
  name: 이메일 인증
  type: graphql
  seq: 5
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation VerifyEmail($token: String!) {
    verifyEmail(token: $token)
  }
}

body:graphql:vars {
  {
    "token": "이메일로 받은 인증 토큰"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
