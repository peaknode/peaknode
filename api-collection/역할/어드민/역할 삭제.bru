meta {
  name: 역할 삭제
  type: graphql
  seq: 5
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: inherit
}

headers {
  Authorization: Bearer {{adminAccessToken}}
}

body:graphql {
  mutation DeleteRole($id: ID!) {
    deleteRole(id: $id)
  }
}

body:graphql:vars {
  {
    "id": "역할-uuid-입력"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
